direction: down

title: |md
  # NFL Betting System — Data Flow
| {near: top-center; shape: text; style.font-size: 24}

# ── External Sources ──

sources: External Data Sources {
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.border-radius: 8

  nflverse: nflverse {shape: cloud; style.fill: "#90caf9"}
  odds: The Odds API {shape: cloud; style.fill: "#90caf9"}
  espn: ESPN {shape: cloud; style.fill: "#90caf9"}
  noaa: NOAA {shape: cloud; style.fill: "#90caf9"}
}

# ── Ingestion ──

ingest: Ingestion {
  style.fill: "#e8eaf6"
  style.stroke: "#283593"
  style.border-radius: 8

  dl: download_data.py {shape: page}
  cache: OddsCache\n(memory → JSON → SQLite) {shape: cylinder; style.fill: "#9fa8da"}
  raw: data/raw/*.parquet {shape: document; style.fill: "#7986cb"; style.font-color: white}
}

sources.nflverse -> ingest.dl: "schedules, PBP,\nweekly stats"
sources.odds -> ingest.cache: "live odds"
sources.espn -> ingest.dl: "scores"
sources.noaa -> ingest.dl: "weather"
ingest.dl -> ingest.raw: parquet

# ── Feature Engineering ──

features: Feature Pipeline {
  style.fill: "#fce4ec"
  style.stroke: "#b71c1c"
  style.border-radius: 8

  builders: |md
    **10 Feature Builders**
    Elo · EPA · Rest · Weather · Form
    Injury (pos-weighted) · Referee (PBP)
    SOS · Market · Encoding
  | {shape: rectangle; style.fill: "#ef9a9a"}

  output: data/processed/\nfeatures_*.parquet {shape: document; style.fill: "#e57373"; style.font-color: white}

  builders -> output: "~55 features"
}

ingest.raw -> features.builders

# ── Model Training ──

training: Model Training {
  style.fill: "#e8f5e9"
  style.stroke: "#1b5e20"
  style.border-radius: 8

  split: Temporal Split\n2016-22 train · 2023 val · 2024 test {shape: parallelogram; style.fill: "#a5d6a7"}
  xgb: XGBoost {shape: rectangle; style.fill: "#66bb6a"}
  lgb: LightGBM {shape: rectangle; style.fill: "#66bb6a"}
  cal: Calibrator {shape: rectangle; style.fill: "#43a047"; style.font-color: white}
  models_dir: models/*.pkl {shape: document; style.fill: "#2e7d32"; style.font-color: white}

  split -> xgb
  split -> lgb
  xgb -> cal
  lgb -> cal
  cal -> models_dir: "joblib.dump"
}

features.output -> training.split

# ── Prediction & Betting ──

predict: Prediction & Betting {
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.border-radius: 8

  loader: ModelLoader\n(singleton cache) {shape: hexagon; style.fill: "#ffcc80"}
  pred: predict_proba() {shape: rectangle; style.fill: "#ffa726"}
  kelly: Kelly Criterion\n(1/4 Kelly) {shape: rectangle; style.fill: "#fb8c00"; style.font-color: white}
  bets: Bet Decisions {shape: rectangle; style.fill: "#ef6c00"; style.font-color: white}

  loader -> pred
  pred -> kelly: "P(home_win)"
  kelly -> bets: "bet size"
}

training.models_dir -> predict.loader: "load .pkl"
features.output -> predict.pred: "features"

# ── Backtesting ──

backtest: Backtesting {
  style.fill: "#fafafa"
  style.stroke: "#424242"
  style.border-radius: 8

  engine: BacktestEngine {shape: rectangle; style.fill: "#e0e0e0"}
  mc: Monte Carlo\n(1000 bootstrap sims) {shape: rectangle; style.fill: "#bdbdbd"}
  metrics: |md
    **Metrics**
    ROI · Win Rate · Sharpe
    Max Drawdown · Edge
    CI₅ / CI₉₅
  | {shape: rectangle; style.fill: "#9e9e9e"; style.font-color: white}

  engine -> mc
  mc -> metrics
}

predict.bets -> backtest.engine

# ── Agent Swarms ──

agents: Agent Swarms {
  style.fill: "#f3e5f5"
  style.stroke: "#4a148c"
  style.border-radius: 8

  consensus: Consensus Swarm\n(deliberation + vote) {shape: rectangle; style.fill: "#ce93d8"}
  validation: Validation Swarm\n(cross-val + stress test) {shape: rectangle; style.fill: "#ce93d8"}
  llm: LLM Council\n(5 providers) {shape: rectangle; style.fill: "#ab47bc"; style.font-color: white}

  consensus -> validation: "strategy"
}

predict.pred -> agents.consensus: "picks"
backtest.metrics -> agents.validation: "backtest results"
agents.llm -> agents.consensus: "reasoning"

# ── Dashboard ──

dash: Streamlit Dashboard\nhttp://localhost:8501 {
  shape: rectangle
  style.fill: "#fff9c4"
  style.stroke: "#f57f17"
  style.border-radius: 12
  style.font-size: 16
  style.bold: true
}

agents.consensus -> dash: "daily picks"
backtest.metrics -> dash: "lab results"
ingest.cache -> dash: "live odds"
